MDBoxLayout:
    orientation: "vertical"

    MDScreenManager:
        id: screen_manager
        MDScreen:
			md_bg_color: self.theme_cls.backgroundColor
            id: home
            name: "home"
			MDLabel:
				theme_font_size: "Custom"
				text: "HARIKO"
				font_size: "50sp"
				adaptive_height: True
				padding: "10dp", "20dp", 0, 0
				pos_hint: {"top": 1}
			FitImage:
				source: "config/anime.png"
				size_hint: 0.7,0.7
				pos_hint: {"top": 0.9, "center_x": 0.5}
			MDButton:
				id: run_widget
				style: "tonal"
				theme_width: "Custom"
				height: "56dp"
				size_hint_x: 1
				pos_hint: {"center_x": .5, "top": 0.2}
				on_press:
					app.start_core()
				MDButtonIcon:
					x: text.x - (self.width + dp(10))
					icon: "run"

				MDButtonText:
					id: text
					text: "start"
					pos_hint: {"center_x": .5, "center_y": .5}
            MDButton:
				style: "tonal"
				theme_width: "Custom"
				height: "56dp"
				size_hint_x: 1
				pos_hint: {"center_x": .5}
				on_press:
					app.file_manager_open()

				MDButtonIcon:
					x: text.x - (self.width + dp(10))
					icon: "plus"

				MDButtonText:
					id: text
					text: "media"
					pos_hint: {"center_x": .5, "center_y": .5}

			
		MDScreen:
			md_bg_color: self.theme_cls.backgroundColor
            id: settings
            name: "settings"
			BoxLayout:
				orientation: "vertical"
				MDLabel:
					theme_font_size: "Custom"
					text: "Settings"
					font_size: "50sp"
					adaptive_height: True
					padding: "10dp", "20dp", 0, 0
					pos_hint: {"top": 1}
				MDScrollView:
					do_scroll_x: False
					MDBoxLayout:
						orientation: "vertical"
						adaptive_height: True
						spacing: dp(12)
						MDListItem:
							MDListItemLeadingIcon:
								icon: "theme-light-dark"

							MDListItemHeadlineText:
								text: "Light theme"

							MDListItemTrailingCheckbox:
								id: theme_checkbox_widget
								active: False
								on_active: app.switch_theme(self.active)
						MDListItem:
							MDListItemLeadingIcon:
								icon: "robot-angry"
							MDListItemHeadlineText:
								text: "Llama GGUF path"
							MDTextField:
								id: gguf_path_widget
								adaptive_height: True
    							mode: "outlined"
								size_hint: 1, 1
						MDListItem:
							MDListItemLeadingIcon:
								icon: "robot-angry"
							MDListItemHeadlineText:
								text: "Whisper language"
							MDListItemSupportingText:
        						text: "Defualt multi-languge (auto)"
							MDTextField:
								id: wp_lang_widget
								adaptive_height: True
    							mode: "outlined"
								size_hint: 1, 1
								text: "auto"
						MDListItem:
							MDListItemLeadingIcon:
								icon: "robot-angry"
							MDListItemHeadlineText:
								text: "Whisper model"
							MDListItemSupportingText:
        						text: "Models: tiny, base, small, medium, large"
							MDTextField:
								id: wp_model_widget
								adaptive_height: True
    							mode: "outlined"
								size_hint: 1, 1
								text: "large"
						MDListItem:
							MDListItemLeadingIcon:
								icon: "cpu-64-bit"
							MDListItemHeadlineText:
								text: "Whisper computing device"
							MDListItemSupportingText:
        						text: "cpu or cuda"
							MDTextField:
								id: wp_cd_widget
								adaptive_height: True
    							mode: "outlined"
								size_hint: 1, 1
								text: "cpu"
				MDButton:
					pos_hint: {"x": 0.8}
					height: "56dp"
    				size_hint_x: .5
					style: "tonal"
					font_size: "30sp"
					adaptive_height: True
					style: "elevated"
					on_press:
						app.update_config()
					MDButtonText:
						text: "Save config"
							

    MDNavigationBar:
		on_switch_tabs: app.on_switch_tabs(*args)

        MDNavigationItem:
			active: True
            MDNavigationItemIcon:
                icon: "home"
            MDNavigationItemLabel:
                text: "home"

		MDNavigationItem:
			active: True
			MDNavigationItemIcon:
				icon: "cog"
			MDNavigationItemLabel:
				text: "settings"

